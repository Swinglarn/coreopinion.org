{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "node build.js",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    {
      "source": "/ideology/:slug",
      "destination": "/ideology"
    },
    {
      "source": "/party/:slug",
      "destination": "/party"
    },
    {
      "source": "/parties",
      "destination": "/party"
    },
    {
      "source": "/parties/:country",
      "destination": "/party"
    },
    {
      "source": "/result/:id",
      "destination": "/api/result-page?id=:id"
    },
    {
      "source": "/compare/:a/:b",
      "destination": "/api/compare-page?a=:a&b=:b"
    }
  ]
}
