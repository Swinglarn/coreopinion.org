  "content": "<div class=\"books-affiliate-disclosure\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"12\" y1=\"16\" x2=\"12\" y2=\"12\"/><line x1=\"12\" y1=\"8\" x2=\"12.01\" y2=\"8\"/></svg> As an Amazon Associate, CoreOpinion earns from qualifying purchases. Links on this page are affiliate links.</div><div class=\"books-region-bar\"><label for=\"region-select\">Your Amazon store:</label><select id=\"region-select\" onchange=\"switchRegion(this.value)\"><option value=\"us\">🇺🇸 United States</option><option value=\"uk\">🇬🇧 United Kingdom</option><option value=\"ca\">🇨🇦 Canada</option><option value=\"au\">🇦🇺 Australia</option><option value=\"nz\">🇳🇿 New Zealand</option><option value=\"se\">🇸🇪 Sweden</option><option value=\"dk\">🇩🇰 Denmark</option><option value=\"no\">🇳🇴 Norway</option><option value=\"fi\">🇫🇮 Finland</option><option value=\"de\">🇩🇪 Germany</option><option value=\"at\">🇦🇹 Austria</option><option value=\"fr\">🇫🇷 France</option><option value=\"es\">🇪🇸 Spain</option><option value=\"it\">🇮🇹 Italy</option><option value=\"ie\">🇮🇪 Ireland</option><option value=\"nl\">🇳🇱 Netherlands</option></select></div><div id=\"books-grid\" class=\"books-grid\"></div><script src=\"/books-data.js\"></script><script>(function(){var currentRegion='us';function detectRegion(){var saved=localStorage.getItem('co_book_region');if(saved&&REGIONS[saved])return saved;var lang=navigator.language||navigator.userLanguage||'en';lang=lang.toLowerCase();var map={'sv':'se','sv-se':'se','da':'dk','da-dk':'dk','nb':'no','nn':'no','nb-no':'no','nn-no':'no','fi':'fi','fi-fi':'fi','de':'de','de-de':'de','de-at':'at','de-ch':'de','fr':'fr','fr-fr':'fr','fr-ca':'ca','fr-be':'fr','es':'es','es-es':'es','it':'it','it-it':'it','nl':'nl','nl-nl':'nl','nl-be':'nl','en-gb':'uk','en-au':'au','en-nz':'nz','en-ca':'ca','en-ie':'ie','en-us':'us','en':'us'};for(var key in map){if(lang===key||lang.startsWith(key+'-'))return map[key];}return 'us';}function getLink(book,region){if(book.links[region]&&book.links[region]!=='#REPLACE_WITH_AFFILIATE_LINK')return book.links[region];if(book.links.us&&book.links.us!=='#REPLACE_WITH_AFFILIATE_LINK')return book.links.us;var domain=REGIONS[region]?REGIONS[region].domain:'amazon.com';return 'https://www.'+domain+'/s?k='+encodeURIComponent(book.title+' '+book.author);}function getCover(isbn){return 'https://covers.openlibrary.org/b/isbn/'+isbn+'-L.jpg';}function fmtYear(y){return y<0?Math.abs(y)+' BC':''+y;}function renderBooks(region){var grid=document.getElementById('books-grid');grid.innerHTML='';BOOKS_DATA.forEach(function(book,i){var link=getLink(book,region);var card=document.createElement('a');card.href=link;card.target='_blank';card.rel='noopener noreferrer sponsored';card.className='book-card';card.style.animationDelay=(i*0.06)+'s';card.innerHTML='<div class=\"book-cover-wrap\"><img src=\"'+getCover(book.isbn)+'\" alt=\"'+book.title+' cover\" loading=\"lazy\" onerror=\"this.parentElement.classList.add(\\'cover-fallback\\');this.alt=\\''+book.title+'\\'\" /></div><div class=\"book-info\"><span class=\"book-category\">'+book.category+'</span><h3 class=\"book-title\">'+book.title+'</h3><p class=\"book-author\">'+book.author+' · '+fmtYear(book.year)+'</p><p class=\"book-desc\">'+book.description+'</p><span class=\"book-cta\">View on Amazon <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M7 17L17 7\"/><path d=\"M7 7h10v10\"/></svg></span></div>';grid.appendChild(card);});}window.switchRegion=function(r){currentRegion=r;localStorage.setItem('co_book_region',r);renderBooks(r);};var detected=detectRegion();currentRegion=detected;document.getElementById('region-select').value=detected;renderBooks(detected);})();</script>"
}
